generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum Role {
  ADMIN
  OWNER
}

enum InsuranceCategory {
  LIFE
  HEALTH
  MOTOR
  TRAVEL
  PROPERTY
  COMMERCIAL
  GENERAL
}

enum PaymentFrequency {
  MONTHLY
  QUARTERLY
  HALF_YEARLY
  YEARLY
  TWO_YEAR
  THREE_YEAR
}

enum PolicyStatus {
  ACTIVE
  PENDING
  EXPIRED
  CANCELLED
}

enum LeadType {
  POSP
  LEAD_EXECUTIVE
  LEADERSHIP
}

enum InvoiceStatus {
  DRAFT
  ISSUED      // legacy — kept for backward compat; new saves use FINALIZED
  FINALIZED
  CANCELLED
}

enum StatementStatus {
  DRAFT       // being built, policies being attached / edited
  FINALIZED   // totals locked, GST computed, ready for invoice generation
  INVOICED    // GST Invoice (BG###) has been generated and linked
  CANCELLED   // withdrawn — policies become available for re-attachment
}

// ── Module 5 — Master data + structured cancellation ───────────────────────

enum InsurerType {
  GENERAL
  HEALTH
  LIFE
}

enum InvoiceCancellationReason {
  DUPLICATE_INVOICE
  INCORRECT_TAXABLE_VALUE
  WRONG_INSURER_SELECTED
  GST_CALCULATION_ERROR
  REPLACED_BY_NEW_INVOICE
  TEST_DUMMY_INVOICE
  CLIENT_REQUEST
  PAYMENT_REVERSED
  OTHER
}

enum CancellationReason {
  CUSTOMER_DECLINED
  CUSTOMER_REQUESTED_CANCELLATION
  PREMIUM_TOO_HIGH
  CUSTOMER_PURCHASED_ELSEWHERE
  CUSTOMER_NOT_REACHABLE
  POLICY_ISSUED_INCORRECTLY
  WRONG_POLICY_DETAILS
  KYC_DOCUMENTS_NOT_PROVIDED
  INSURER_REJECTED_PROPOSAL
  PAYMENT_NOT_RECEIVED
  PROPOSAL_EXPIRED
  POLICY_REPLACED
  RENEWAL_NOT_PROCEEDED
  DUPLICATE_ENTRY
  DUPLICATE_POLICY_IMPORTED
  TEST_DUMMY_ENTRY
  OTHER
}

// ─── Models ───────────────────────────────────────────────────────────────────

// ── Master Tables (Module 2 — Phase 1) ───────────────────────────────────────
// These are independent reference tables. Policy still keeps free-text
// insurerName / productName / leadSource for backward compatibility.

model Insurer {
  id            Int           @id @default(autoincrement())
  name          String        @unique
  insurerType   InsurerType?                          // Module 5 — General/Health/Life
  gstin         String?                               // Module 5 — reference metadata (separate from InsurerInvoiceProfile.gstin)
  state         String?                               // Module 5 — reference metadata
  active        Boolean       @default(true)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  products        Product[]
  invoiceProfile  InsurerInvoiceProfile?
  invoices        Invoice[]
  statements      InsurerStatement[]

  @@map("insurers")
}

model Product {
  id                Int                @id @default(autoincrement())
  name              String
  insurerId         Int
  insurer           Insurer            @relation(fields: [insurerId], references: [id], onDelete: Cascade)
  insuranceCategory InsuranceCategory?                    // Module 5 — product-level classification
  active            Boolean            @default(true)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  @@unique([insurerId, name])
  @@map("products")
}

model LeadMember {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  leadType  LeadType
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  incentives Incentive[]
  dailyIncentiveEntries IncentiveEntry[]

  @@map("lead_members")
}

// ── Phase 4 — Daily Incentive Tracking ───────────────────────────────────────
// Configurable point values used to calculate daily incentive entries.
// Singleton row (id = 1). All values default to 0 — no business rules are
// hardcoded; Admin must configure these before calculations produce non-zero
// results.

model IncentiveSetting {
  id Int @id @default(autoincrement())

  touchBasePoints       Decimal @db.Decimal(10, 2) @default(0)
  interestedPoints      Decimal @db.Decimal(10, 2) @default(0)
  followUpPoints        Decimal @db.Decimal(10, 2) @default(0)
  conversionPoints      Decimal @db.Decimal(10, 2) @default(0)
  lifeConversionPoints  Decimal @db.Decimal(10, 2) @default(0)
  healthConversionPoints Decimal @db.Decimal(10, 2) @default(0)
  amountPerPoint        Decimal @db.Decimal(10, 2) @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("incentive_settings")
}

// One row per employee per day. calculatedPoints/calculatedAmount are frozen
// at create/update time using the IncentiveSetting values in effect then —
// future setting changes do not retroactively alter saved entries.

model IncentiveEntry {
  id Int @id @default(autoincrement())

  employeeId Int
  employee   LeadMember @relation(fields: [employeeId], references: [id])

  date DateTime

  totalCalls      Int     @default(0)
  touchBase       Int     @default(0)
  interested      Int     @default(0)
  followUp        Int     @default(0)
  conversion      Int     @default(0)
  conversionType  String?

  calculatedPoints Decimal @db.Decimal(10, 2)
  calculatedAmount Decimal @db.Decimal(18, 2)

  remarks String?

  createdById Int
  createdBy   User @relation(fields: [createdById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([employeeId, date])
  @@index([date])
  @@map("incentive_entries")
}

// ── Lead Executive Incentives ────────────────────────────────────────────────
// Manually entered monthly point totals for Lead Executives. Standalone module —
// no relation to Policy, commission, or invoice data.

model Incentive {
  id Int @id @default(autoincrement())

  leadMemberId Int
  leadMember   LeadMember @relation(fields: [leadMemberId], references: [id])

  month String // "YYYY-MM"

  points          Decimal @db.Decimal(10, 2)
  pointValue      Decimal @db.Decimal(10, 2) @default(0.50)
  incentiveAmount Decimal @db.Decimal(18, 2)

  remarks String?

  createdById Int
  createdBy   User @relation("IncentiveCreatedBy", fields: [createdById], references: [id])

  isDeleted  Boolean   @default(false)
  deletedAt  DateTime?
  deletedById Int?
  deletedBy   User?    @relation("IncentiveDeletedBy", fields: [deletedById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([leadMemberId, month])
  @@map("incentives")
}

// ── Invoice Phase 1 ─────────────────────────────────────────────────────────
// One row per insurer holding GST recipient details for tax invoices.
// 1:1 with Insurer. Completely independent of Policy — no aggregation logic
// yet. Invoice generation is Phase 2.

model InsurerInvoiceProfile {
  id              Int      @id @default(autoincrement())
  insurerId       Int      @unique
  insurer         Insurer  @relation(fields: [insurerId], references: [id], onDelete: Cascade)

  recipientHeader String   // short title used on invoice header e.g. "STAR Health"
  legalName       String   // full company name e.g. "Star Health Allied Insurance Co Ltd"
  billingAddress  String   @db.Text
  state           String   // e.g. "Tamil Nadu"
  stateCode       String   // e.g. "033"
  gstin           String

  active          Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("insurer_invoice_profiles")
}


model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(OWNER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  policies          Policy[]            @relation("PolicyCreatedBy")
  cancelledPolicies Policy[]            @relation("PolicyCancelledBy")    // Module 5
  invoices          Invoice[]
  cancelledInvoices Invoice[]           @relation("InvoiceCancelledBy")   // Module 5
  statements        InsurerStatement[]
  incentives        Incentive[]         @relation("IncentiveCreatedBy")
  deletedIncentives Incentive[]         @relation("IncentiveDeletedBy")
  dailyIncentiveEntries IncentiveEntry[]
  pospMembersCreated    POSPMember[]              @relation("POSPMemberCreatedBy")
  pospOverrides         POSPCommissionOverride[]  @relation("POSPOverrideCreatedBy")
  pospEntriesCreated    POSPIncentiveEntry[]      @relation("POSPEntryCreatedBy")

  @@map("users")
}

// ── POSP Module ───────────────────────────────────────────────────────────────

model POSPMember {
  id          Int       @id @default(autoincrement())
  name        String
  code        String    @unique
  mobile      String?
  email       String?
  joiningDate DateTime?
  status      String    @default("ACTIVE")
  remarks     String?
  isDeleted   Boolean   @default(false)
  deletedAt   DateTime?

  commissionOverrides POSPCommissionOverride[]
  incentiveEntries    POSPIncentiveEntry[]

  createdById Int
  createdBy   User @relation("POSPMemberCreatedBy", fields: [createdById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("posp_members")
}

model POSPCommissionOverride {
  id             Int        @id @default(autoincrement())
  pospMemberId   Int
  pospMember     POSPMember @relation(fields: [pospMemberId], references: [id])
  policyId       Int
  commissionRate Decimal    @db.Decimal(8, 4)
  brokerageAmount Decimal   @db.Decimal(18, 2)

  createdById Int
  createdBy   User @relation("POSPOverrideCreatedBy", fields: [createdById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([pospMemberId, policyId])
  @@map("posp_commission_overrides")
}

// One row per policy assigned to a POSP member for payout tracking.
// policyId is optional — null means a manual entry not linked to the Policy module.
model POSPIncentiveEntry {
  id             Int        @id @default(autoincrement())
  pospMemberId   Int
  pospMember     POSPMember @relation(fields: [pospMemberId], references: [id])

  // Optional link to existing Policy record
  policyId       Int?       // null = manual entry
  isManual       Boolean    @default(false)
  isImported     Boolean    @default(false)   // true = row came from Excel import

  // Policy register fields (copied from Policy when linked, or entered manually)
  entryDate      DateTime
  policyNumber   String
  customerName   String
  policyType     String?    // free-text: Motor, Health, Life, etc.

  // Financial fields — all calculations done in service layer only
  premium        Decimal    @db.Decimal(18, 2)
  commissionRate Decimal    @db.Decimal(6, 2)   // e.g. 12.00 = 12%
  pospShare      Decimal    @db.Decimal(6, 2)   // e.g. 65.00 = 65%
  brokerage      Decimal    @db.Decimal(18, 2)  // premium × commissionRate / 100
  pospCommission Decimal    @db.Decimal(18, 2)  // brokerage × pospShare / 100
  orgCommission  Decimal    @db.Decimal(18, 2)  // brokerage − pospCommission

  // Payment tracking
  paymentStatus  String     @default("PENDING") // PENDING | PAID | PARTIALLY_PAID

  // Invoice tracking
  invoiceReference String?
  invoiceDate      DateTime?
  remarks          String?

  // Audit
  createdById    Int
  createdBy      User       @relation("POSPEntryCreatedBy", fields: [createdById], references: [id])
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  // Soft delete
  isDeleted      Boolean    @default(false)
  deletedAt      DateTime?

  @@index([pospMemberId])
  @@index([entryDate])
  @@map("posp_incentive_entries")
}

model Policy {
  id Int @id @default(autoincrement())

  // ── Insurer & Product ─────────────────────────────────────────────────────
  insurerName       String
  insuranceCategory InsuranceCategory
  productName       String

  // ── Customer ──────────────────────────────────────────────────────────────
  customerName  String
  customerPhone String?
  customerEmail String?

  // ── Policy Info ───────────────────────────────────────────────────────────
  policyNumber     String           @unique
  issueDate        DateTime
  renewalDate      DateTime
  nextDueDate      DateTime?
  paymentFrequency PaymentFrequency
  status           PolicyStatus     @default(ACTIVE)

  // ── Financial (all Decimal for accuracy) ──────────────────────────────────
  grossPremium      Decimal  @db.Decimal(18, 2)
  netPremium        Decimal  @db.Decimal(18, 2)
  gstPercent        Decimal  @db.Decimal(8, 4)
  gstAmount         Decimal  @db.Decimal(18, 2)
  commissionPercent Decimal  @db.Decimal(8, 4)
  commissionAmount  Decimal  @db.Decimal(18, 2)
  tdsPercent        Decimal  @db.Decimal(8, 4)
  tdsAmount         Decimal  @db.Decimal(18, 2)
  finalReceivable   Decimal  @db.Decimal(18, 2)

  // ── Business / Tracking ───────────────────────────────────────────────────
  leadSource    String
  invoiceNumber String?
  invoiceDate   DateTime?
  creditedDate  DateTime?
  paymentMode   String?
  remarks       String?

  // ── Phase 1 — Invoice Raised Tracking ─────────────────────────────────────
  invoiceRaised   Boolean   @default(false)
  invoiceRaisedAt DateTime?

  // ── Audit ─────────────────────────────────────────────────────────────────
  createdById Int
  createdBy   User     @relation("PolicyCreatedBy", fields: [createdById], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // ── Module 3 — GST Statement linkage (junction table) ─────────────────────
  statementPolicies StatementPolicy[]

  // ── Module 5 — Structured cancellation ────────────────────────────────────
  cancellationReason      CancellationReason?
  cancellationReasonOther String?
  cancelledAt             DateTime?
  cancelledById           Int?
  cancelledBy             User?               @relation("PolicyCancelledBy", fields: [cancelledById], references: [id])

  @@map("policies")
}

// ── Invoice Phase 2 ─────────────────────────────────────────────────────────
// One row per GST tax invoice generated for an insurer + month.
// Recipient block is snapshot-stored so future address changes don't alter
// historical invoices. Policy schema is NOT linked — aggregation happens at
// generation time via Policy.insurerName + issueDate match.

model Invoice {
  id            Int      @id @default(autoincrement())
  invoiceNumber String   @unique
  invoiceDate   DateTime
  insurerId     Int
  insurer       Insurer  @relation(fields: [insurerId], references: [id])
  insurerName   String?                         // snapshot — frozen at save; insurer renames don't affect history
  billingMonth  String                          // "YYYY-MM"

  description   String                          // "Brokerage for the month of March 2026"
  lineItemText  String                          // "Vehicle Insurance - 10 Nos"
  policyCount   Int

  // ── Tax block (computed at generation, frozen on save) ────────────────────
  taxableValue  Decimal  @db.Decimal(18, 2)
  cgstRate      Decimal  @db.Decimal(5, 2)
  cgstAmount    Decimal  @db.Decimal(18, 2)
  sgstRate      Decimal  @db.Decimal(5, 2)
  sgstAmount    Decimal  @db.Decimal(18, 2)
  igstRate      Decimal  @db.Decimal(5, 2)
  igstAmount    Decimal  @db.Decimal(18, 2)
  totalAmount   Decimal  @db.Decimal(18, 2)
  totalInWords  String

  // ── Recipient snapshot (frozen at issue time) ─────────────────────────────
  recipientHeader     String
  recipientLegalName  String
  recipientAddress    String  @db.Text
  recipientState      String
  recipientStateCode  String
  recipientGstin      String

  status        InvoiceStatus  @default(DRAFT)
  notes         String?
  isGstExempt   Boolean        @default(false)   // Module 4 — report classification flag

  // ── Module 5 — Structured cancellation ────────────────────────────────────
  cancellationReason      InvoiceCancellationReason?
  cancellationReasonOther String?
  cancelledAt             DateTime?
  cancelledById           Int?
  cancelledBy             User?          @relation("InvoiceCancelledBy", fields: [cancelledById], references: [id])

  createdById   Int
  createdBy     User           @relation(fields: [createdById], references: [id])
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  // ── Module 3 — Reverse relation to the statement this invoice was generated from (if any) ─
  statement     InsurerStatement?

  @@index([insurerId, billingMonth])
  @@map("invoices")
}

// ── Module 3 — GST Statement Workflow ───────────────────────────────────────
// One row per brokerage statement received from an insurer.
// Statement totals are frozen at FINALIZED time; the linked Invoice (if any)
// is generated from the same frozen values.

model InsurerStatement {
  id                 Int       @id @default(autoincrement())
  insurerId          Int
  insurer            Insurer   @relation(fields: [insurerId], references: [id])

  statementRefNo     String    // insurer-provided reference number
  statementDate      DateTime  // date printed on the statement document
  creditDate         DateTime? // when funds landed in BIGIN's account (optional)
  businessMonth      String    // "YYYY-MM" — the month brokerage relates to
  remarks            String?
  statementFileUrl   String?   // optional path/URL to uploaded statement file for audit

  // ── Module 4 — Bank credit details (populated when money actually arrives) ─
  // Only editable when status = INVOICED. amountCredited may differ from
  // invoiceValue due to TDS, bank charges, partial credits, etc.
  amountCredited     Decimal?  @db.Decimal(18, 2)
  bankReference      String?   // e.g. "S98019073" or "CMS5587231631"
  bankAccount        String?   // e.g. "Bank-1 (Old)" / "Bank-2 (New)" — free text
  natureOfTransaction String?  // e.g. "Brokerage Credit", "TDS Reversal" — for Monthly GST Report

  // ── Frozen totals — populated by finalize(); zero while DRAFT ────────────
  totalTaxableValue  Decimal   @db.Decimal(18, 2) @default(0)
  cgstRate           Decimal   @db.Decimal(5, 2)  @default(0)
  cgstAmount         Decimal   @db.Decimal(18, 2) @default(0)
  sgstRate           Decimal   @db.Decimal(5, 2)  @default(0)
  sgstAmount         Decimal   @db.Decimal(18, 2) @default(0)
  igstRate           Decimal   @db.Decimal(5, 2)  @default(0)
  igstAmount         Decimal   @db.Decimal(18, 2) @default(0)
  invoiceValue       Decimal   @db.Decimal(18, 2) @default(0)

  status             StatementStatus @default(DRAFT)

  // Generated GST Invoice (nullable until generateInvoice() runs)
  invoiceId          Int?      @unique
  invoice            Invoice?  @relation(fields: [invoiceId], references: [id])

  policies           StatementPolicy[]

  createdById        Int
  createdBy          User      @relation(fields: [createdById], references: [id])
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@unique([insurerId, statementRefNo])
  @@index([insurerId, statementDate])
  @@index([status])
  @@map("insurer_statements")
}

model StatementPolicy {
  id            Int      @id @default(autoincrement())

  statementId   Int
  statement     InsurerStatement @relation(fields: [statementId], references: [id], onDelete: Cascade)

  policyId      Int
  policy        Policy   @relation(fields: [policyId], references: [id])

  taxableValue  Decimal  @db.Decimal(18, 2)

  createdAt     DateTime @default(now())

  // A policy cannot appear twice in the same statement (service layer also
  // enforces "policy cannot be in two non-cancelled statements").
  @@unique([statementId, policyId])
  @@index([policyId])
  @@map("statement_policies")
}
